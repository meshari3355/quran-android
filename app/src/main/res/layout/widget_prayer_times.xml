<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_prayer_background"
    android:gravity="center_vertical"
    android:orientation="vertical"
    android:padding="18dp">

    <TextView
        android:id="@+id/widget_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:fontFamily="sans"
        android:gravity="end"
        android:maxLines="1"
        android:text="@string/app_name"
        android:textColor="#B88700"
        android:textSize="15sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widget_subtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="end"
        android:text="الصلاة القادمة"
        android:textColor="#857C70"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/widget_next_prayer_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:ellipsize="end"
        android:gravity="end"
        android:maxLines="1"
        android:text="الصلاة القادمة"
        android:textColor="#1C1A2E"
        android:textSize="25sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widget_next_prayer_time"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:gravity="end"
        android:text="--:--"
        android:textColor="#B88700"
        android:textSize="31sp"
        android:textStyle="bold" />
</LinearLayout>
